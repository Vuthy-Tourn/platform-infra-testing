/**
 * Microservices Orchestrator Pipeline
 *
 * Best-practice test flow:
 *   1. Resolve one release plan for all services.
 *   2. Build / scan / push each service independently.
 *   3. If GitOps is enabled, batch all service manifest updates into one commit.
 *
 * This keeps one service per deployable unit while avoiding one GitOps push per service.
 */
pipeline {
    agent none

    options {
        timeout(time: 90, unit: 'MINUTES')
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '30'))
    }

    parameters {
        string(name: 'USER_ID', defaultValue: '', description: 'Tenant user ID')
        string(name: 'WORKSPACE_ID', defaultValue: '', description: 'Workspace ID / slug')
        string(name: 'PROJECT_NAME', defaultValue: 'workspace-stack', description: 'Workspace-level stack name written to GitOps')
        string(name: 'PLATFORM_DOMAIN', defaultValue: 'apps.example.com', description: 'Wildcard platform domain')
        string(name: 'GITOPS_BRANCH', defaultValue: 'main', description: 'GitOps branch to update')
        string(name: 'SERVICE_JOB_NAME', defaultValue: 'deploy-service-test', description: 'Jenkins job name used to deploy one service')
        booleanParam(name: 'ENABLE_TRIVY_SCAN', defaultValue: false, description: 'Run Trivy scan on each service image')
        booleanParam(name: 'ENABLE_GITOPS_UPDATE', defaultValue: false, description: 'Update GitOps repository once after all service builds succeed')
        booleanParam(name: 'ROLLBACK_MODE', defaultValue: false, description: 'Rollback all services to saved image tags')
        string(name: 'SERVICES_JSON', defaultValue: '[]', description: 'JSON array of service descriptors (backend-provided)')
    }

    environment {
        INFRA_REPO_URL      = credentials('infra-repo-url-micro')
        REGISTRY_REPOSITORY = credentials('registry-repository-micro')
        GITOPS_REPO_URL     = credentials('gitops-repo-url-micro')
    }

    stages {
        stage('Validate') {
            agent any
            steps {
                script {
                    if (!params.USER_ID?.trim()) {
                        error('USER_ID is required')
                    }
                    if (!params.SERVICES_JSON?.trim() || params.SERVICES_JSON.trim() == '[]') {
                        error('SERVICES_JSON is required and must not be empty')
                    }

                    def services
                    try {
                        services = parseJson(params.SERVICES_JSON)
                    } catch (Exception e) {
                        error("SERVICES_JSON is not valid JSON: ${e.message}")
                    }

                    if (!(services instanceof List) || services.isEmpty()) {
                        error('SERVICES_JSON must be a non-empty JSON array')
                    }

                    services.each { svc ->
                        if (!svc.name?.toString()?.trim()) {
                            error("Service entry missing 'name': ${svc}")
                        }
                        if (!params.ROLLBACK_MODE && !svc.repoUrl?.toString()?.trim()) {
                            error("Service '${svc.name}' missing 'repoUrl'")
                        }
                        if (params.ROLLBACK_MODE && !svc.imageTag?.toString()?.trim()) {
                            error("Service '${svc.name}' missing 'imageTag' for rollback")
                        }
                        if (params.ROLLBACK_MODE && !svc.framework?.toString()?.trim()) {
                            error("Service '${svc.name}' missing 'framework' for rollback")
                        }
                    }

                    env.EFFECTIVE_WORKSPACE_ID = params.WORKSPACE_ID?.trim() ?: params.USER_ID.trim()
                    env.SAFE_USER_ID = slugify(params.USER_ID, 30)
                    env.SAFE_WORKSPACE_ID = slugify(env.EFFECTIVE_WORKSPACE_ID, 30)
                    env.SAFE_STACK_NAME = slugify(params.PROJECT_NAME?.trim() ?: 'workspace-stack', 40)

                    def registryContext = resolveRegistryContext(env.REGISTRY_REPOSITORY ?: '')
                    env.NORMALIZED_REGISTRY_REPOSITORY = registryContext.repositoryRoot
                    env.REGISTRY_LOGIN_SERVER = registryContext.loginServer
                    env.DOCKER_HUB_MODE = registryContext.dockerHubMode.toString()

                    echo "Validated ${services.size()} service(s) for workspace ${env.EFFECTIVE_WORKSPACE_ID}"
                    echo "Workspace stack name: ${env.SAFE_STACK_NAME}"
                    echo "Downstream service job: ${params.SERVICE_JOB_NAME}"
                }
            }
        }

        stage('Checkout infra') {
            agent any
            steps {
                dir('platform-infra') {
                    checkout([
                        $class: 'GitSCM',
                        branches: [[name: '*/main']],
                        userRemoteConfigs: [[
                            url: env.INFRA_REPO_URL,
                            credentialsId: 'infra-repo-creds'
                        ]]
                    ])
                }
                script {
                    env.INFRA_SCRIPTS_DIR = sh(
                        script: '''
                            set -e
                            for d in "$WORKSPACE/platform-infra/jenkins/scripts" "$WORKSPACE/plateform-infra/jenkins/scripts"; do
                                if [ -f "$d/detect-framework.sh" ]; then
                                    echo "$d"
                                    exit 0
                                fi
                            done
                            echo "ERROR: infra Jenkins scripts directory not found." >&2
                            exit 1
                        ''',
                        returnStdout: true
                    ).trim()
                }
            }
        }

        stage('Resolve deploy order') {
            agent any
            steps {
                script {
                    def services = parseJson(params.SERVICES_JSON)
                    def ordered = topologicalSort(services)
                    env.ORDERED_SERVICE_NAMES = ordered.collect { it.name }.join(',')
                    env.ORDERED_SERVICES_STATE = encodeServicesForState(ordered)
                    echo "Deploy order: ${env.ORDERED_SERVICE_NAMES}"
                }
            }
        }

        stage('Prepare release plan') {
            agent any
            steps {
                script {
                    def services = decodeServicesFromState(env.ORDERED_SERVICES_STATE)
                    def syncWaveByService = buildSyncWaveMap(services)
                    def plannedServices = []

                    services.eachWithIndex { svc, index ->
                        def serviceName = svc.name.toString().trim()
                        def safeProjectName = slugify(serviceName, 40)
                        def imageRepository = buildImageRepository(
                            env.NORMALIZED_REGISTRY_REPOSITORY,
                            safeProjectName,
                            env.SAFE_USER_ID,
                            env.DOCKER_HUB_MODE?.toBoolean()
                        )

                        def branch = svc.branch?.toString()?.trim() ?: 'main'
                        def frameworkOverride = svc.framework?.toString()?.trim() ?: ''
                        def metadata = params.ROLLBACK_MODE
                            ? [
                                commitSha: "rollback-${svc.imageTag.toString().trim()}",
                                framework: frameworkOverride
                            ]
                            : resolveCommitAndFramework(
                                svc,
                                branch,
                                safeProjectName,
                                index,
                                frameworkOverride
                            )
                        def commitSha = metadata.commitSha
                        def framework = metadata.framework
                        def imageTag = svc.imageTag?.toString()?.trim()
                            ? svc.imageTag.toString().trim()
                            : "${env.SAFE_USER_ID}-${env.BUILD_NUMBER}-${commitSha}"

                        plannedServices << [
                            name               : serviceName,
                            repoUrl            : svc.repoUrl?.toString()?.trim() ?: '',
                            branch             : branch,
                            repoCredentialsId  : svc.repoCredentialsId?.toString()?.trim() ?: '',
                            framework          : framework,
                            appPort            : svc.appPort?.toString()?.trim() ?: '8080',
                            imageTag           : imageTag,
                            envJson            : svc.envJson?.toString()?.trim() ?: '[]',
                            relationshipsToken : svc.relationshipsToken ?: '',
                            dependsOn          : svc.dependsOn ?: [],
                            serviceType        : svc.serviceType?.toString()?.trim() ?: 'internal',
                            mergedEnvJson      : mergeEnvAndRelationships(
                                svc.envJson?.toString()?.trim() ?: '[]',
                                svc.relationshipsToken?.toString() ?: ''
                            ),
                            imageRepository    : imageRepository,
                            commitSha          : commitSha,
                            customDomain       : svc.customDomain?.toString()?.trim() ?: '',
                            syncWave           : (syncWaveByService[serviceName] ?: 0).toString()
                        ]
                    }

                    env.PLANNED_SERVICES_STATE = encodeServicesForState(plannedServices)
                    echo "Prepared release plan for ${plannedServices.size()} service(s)"
                }
            }
        }

        stage('Build and push services') {
            agent none
            steps {
                script {
                    def services = decodeServicesFromState(env.PLANNED_SERVICES_STATE)
                    def failures = []

                    services.each { svc ->
                        echo "=== Building service: ${svc.name} (type: ${svc.serviceType}) ==="

                        try {
                            build job: params.SERVICE_JOB_NAME,
                                wait: true,
                                propagate: true,
                                parameters: [
                                    string(name: 'REPO_URL', value: svc.repoUrl),
                                    string(name: 'BRANCH', value: svc.branch),
                                    string(name: 'USER_ID', value: params.USER_ID),
                                    string(name: 'WORKSPACE_ID', value: env.EFFECTIVE_WORKSPACE_ID),
                                    string(name: 'PROJECT_NAME', value: svc.name),
                                    string(name: 'APP_PORT', value: svc.appPort),
                                    string(name: 'FRAMEWORK', value: svc.framework),
                                    string(name: 'IMAGE_TAG', value: svc.imageTag),
                                    string(name: 'ENV_JSON', value: svc.mergedEnvJson),
                                    string(name: 'SERVICE_TYPE', value: svc.serviceType),
                                    string(name: 'PLATFORM_DOMAIN', value: params.PLATFORM_DOMAIN),
                                    string(name: 'GITOPS_BRANCH', value: params.GITOPS_BRANCH),
                                    string(name: 'REPO_CREDENTIALS_ID', value: svc.repoCredentialsId),
                                    booleanParam(name: 'ENABLE_TRIVY_SCAN', value: params.ENABLE_TRIVY_SCAN),
                                    booleanParam(name: 'ENABLE_GITOPS_UPDATE', value: false),
                                    booleanParam(name: 'ROLLBACK_MODE', value: params.ROLLBACK_MODE)
                                ]
                            echo "=== ${svc.name}: built successfully ==="
                        } catch (Exception e) {
                            echo "=== ${svc.name}: FAILED — ${e.message} ==="
                            failures << svc.name
                        }
                    }

                    if (failures) {
                        error("The following services failed to build/deploy: ${failures.join(', ')}")
                    }
                }
            }
        }

        stage('Update GitOps repository (batched)') {
            when {
                expression { return params.ENABLE_GITOPS_UPDATE }
            }
            agent any
            steps {
                dir('platform-infra') {
                    checkout([
                        $class: 'GitSCM',
                        branches: [[name: '*/main']],
                        userRemoteConfigs: [[
                            url: env.INFRA_REPO_URL,
                            credentialsId: 'infra-repo-creds'
                        ]]
                    ])
                }
                script {
                    def services = decodeServicesFromState(env.PLANNED_SERVICES_STATE)
                    def operation = params.ROLLBACK_MODE ? 'rollback' : 'deploy'
                    def workspaceCommitMessage = "${operation}(workspace/${env.SAFE_WORKSPACE_ID}/${env.SAFE_USER_ID}/${env.SAFE_STACK_NAME}): ${services.size()} service(s) build=${env.BUILD_NUMBER}"
                    def workspaceServicesJson = servicesStateToJson(env.PLANNED_SERVICES_STATE)

                    withCredentials([usernamePassword(
                        credentialsId: 'gitops-micro-creds',
                        usernameVariable: 'GITOPS_USERNAME',
                        passwordVariable: 'GITOPS_TOKEN'
                    )]) {
                        sh '''
                            set -e
                            test -f "$WORKSPACE/platform-infra/jenkins/scripts/update-gitops.sh"
                            rm -rf "$WORKSPACE/gitops-batch"
                            AUTHED_GITOPS_REPO_URL="${GITOPS_REPO_URL}"
                            case "$AUTHED_GITOPS_REPO_URL" in
                              https://*)
                                AUTHED_GITOPS_REPO_URL="$(printf '%s' "$AUTHED_GITOPS_REPO_URL" | sed "s#^https://#https://${GITOPS_USERNAME}:${GITOPS_TOKEN}@#")"
                                ;;
                              http://*)
                                AUTHED_GITOPS_REPO_URL="$(printf '%s' "$AUTHED_GITOPS_REPO_URL" | sed "s#^http://#http://${GITOPS_USERNAME}:${GITOPS_TOKEN}@#")"
                                ;;
                            esac
                            git clone --branch "${GITOPS_BRANCH}" --depth 1 "${AUTHED_GITOPS_REPO_URL}" "$WORKSPACE/gitops-batch" >/dev/null
                            git -C "$WORKSPACE/gitops-batch" config user.email "jenkins@platform.local"
                            git -C "$WORKSPACE/gitops-batch" config user.name "${GITOPS_USERNAME}"
                            git -C "$WORKSPACE/gitops-batch" remote set-url origin "${AUTHED_GITOPS_REPO_URL}"
                        '''

                        withEnv([
                            "BATCH_OPERATION=${operation}",
                            "BATCH_PROJECT_NAME=${env.SAFE_STACK_NAME}",
                            "BATCH_SERVICES_JSON=${workspaceServicesJson}"
                        ]) {
                            sh '''
                                set -e
                                bash "$WORKSPACE/platform-infra/jenkins/scripts/update-gitops.sh" \
                                  --gitops-repo "${GITOPS_REPO_URL}" \
                                  --gitops-branch "${GITOPS_BRANCH}" \
                                  --gitops-workdir "$WORKSPACE/gitops-batch" \
                                  --infra-repo "${INFRA_REPO_URL}" \
                                  --infra-revision "main" \
                                  --chart-path "helm/app-template" \
                                  --operation "${BATCH_OPERATION}" \
                                  --workspace-id "${EFFECTIVE_WORKSPACE_ID}" \
                                  --user-id "${USER_ID}" \
                                  --project-name "${BATCH_PROJECT_NAME}" \
                                  --services-json "${BATCH_SERVICES_JSON}" \
                                  --platform-domain "${PLATFORM_DOMAIN}" \
                                  --commit-sha "workspace-${BUILD_NUMBER}" \
                                  --build-number "${BUILD_NUMBER}" \
                                  --skip-push true
                            '''
                        }

                        withEnv(["BATCH_COMMIT_MESSAGE=${workspaceCommitMessage}"]) {
                            sh '''
                                set -e
                                cd "$WORKSPACE/gitops-batch"
                                git add apps applications templates
                                if git diff --cached --quiet; then
                                  echo "No batched GitOps changes required."
                                  exit 0
                                fi
                                git commit -m "${BATCH_COMMIT_MESSAGE}" >/dev/null
                                git push origin "${GITOPS_BRANCH}" >/dev/null
                            '''
                        }
                    }
                }
            }
        }
    }

    post {
        success {
            echo "All services processed successfully for workspace ${env.EFFECTIVE_WORKSPACE_ID}"
        }
        failure {
            echo "One or more services failed. Check orchestrator logs."
        }
        always {
            script {
                if (getContext(hudson.FilePath)) {
                    cleanWs()
                } else {
                    echo 'Skipping workspace cleanup because no workspace is active.'
                }
            }
        }
    }
}

def topologicalSort(List services) {
    def nameToSvc = services.collectEntries { [(it.name): it] }
    def inDegree = services.collectEntries { [(it.name): 0] }
    def graph = services.collectEntries { [(it.name): []] }

    services.each { svc ->
        (svc.dependsOn ?: []).each { dep ->
            if (nameToSvc.containsKey(dep)) {
                graph[dep] << svc.name
                inDegree[svc.name] = (inDegree[svc.name] ?: 0) + 1
            } else {
                echo "WARNING: '${svc.name}' depends on unknown service '${dep}' — ignoring"
            }
        }
    }

    def queue = inDegree.findAll { it.value == 0 }.keySet().toList()
    def ordered = []

    while (!queue.isEmpty()) {
        def current = queue.remove(0)
        ordered << nameToSvc[current]
        graph[current].each { neighbour ->
            inDegree[neighbour]--
            if (inDegree[neighbour] == 0) {
                queue << neighbour
            }
        }
    }

    if (ordered.size() != services.size()) {
        echo "WARNING: Cycle detected in dependsOn graph — falling back to original order"
        return services
    }

    ordered
}

def buildSyncWaveMap(List services) {
    def nameToSvc = services.collectEntries { [(it.name): it] }
    def waveByName = [:]

    services.each { svc ->
        def dependencies = (svc.dependsOn ?: []).findAll { dep -> nameToSvc.containsKey(dep) }
        if (!dependencies) {
            waveByName[svc.name] = 0
        } else {
            def maxWave = 0
            dependencies.each { dep ->
                def dependencyWave = (waveByName[dep] ?: 0) as Integer
                if (dependencyWave > maxWave) {
                    maxWave = dependencyWave
                }
            }
            waveByName[svc.name] = maxWave + 1
        }
    }

    waveByName
}

def parseJson(String text) {
    def tempFile = '.jenkins-services.json'
    writeFile file: tempFile, text: text ?: '[]'

    try {
        def output = sh(
            script: """python3 - '${tempFile}' <<'PY'
import base64
import json
import sys

with open(sys.argv[1], 'r', encoding='utf-8') as handle:
    payload = json.load(handle)

if payload is None:
    payload = []

if not isinstance(payload, list):
    raise SystemExit("Expected a JSON array.")

fields = [
    "name",
    "repoUrl",
    "branch",
    "repoCredentialsId",
    "framework",
    "appPort",
    "imageTag",
    "envJson",
    "serviceType",
    "customDomain",
    "imageRepository",
    "commitSha",
    "mergedEnvJson",
]

for svc in payload:
    if not isinstance(svc, dict):
        raise SystemExit("Expected each service entry to be an object.")

    depends_on = svc.get("dependsOn") or []
    if not isinstance(depends_on, list):
        depends_on = []

    if "relationshipsToken" in svc and svc.get("relationshipsToken") is not None:
        relationships_token = str(svc.get("relationshipsToken"))
    else:
        relationships_json = json.dumps(svc.get("relationships") or [], separators=(",", ":"))
        relationships_token = base64.b64encode(relationships_json.encode("utf-8")).decode("ascii")

    values = [str(svc.get(field) or "") for field in fields]
    values.append("\\u001f".join(str(item or "") for item in depends_on if str(item or "")))
    values.append(relationships_token)
    print("\\t".join(value.replace("\\t", " ").replace("\\n", " ") for value in values))
PY""",
            returnStdout: true
        ).trim()

        if (!output) {
            return []
        }

        output.readLines().collect { line ->
            def columns = line.split('\\t', -1)
            [
                name              : columns[0],
                repoUrl           : columns[1],
                branch            : columns[2],
                repoCredentialsId : columns[3],
                framework         : columns[4],
                appPort           : columns[5],
                imageTag          : columns[6],
                envJson           : columns[7],
                serviceType       : columns[8],
                customDomain      : columns[9],
                imageRepository   : columns[10],
                commitSha         : columns[11],
                mergedEnvJson     : columns[12],
                dependsOn         : columns[13] ? columns[13].split('\u001f').findAll { it } : [],
                relationshipsToken: columns[14]
            ]
        }
    } finally {
        sh "rm -f '${tempFile}'"
    }
}

def mergeEnvAndRelationships(String envJson, String relationshipsToken) {
    def envTempFile = '.jenkins-env.json'
    writeFile file: envTempFile, text: envJson ?: '[]'

    try {
        sh(
            script: """python3 - '${envTempFile}' '${relationshipsToken ?: ''}' <<'PY'
import base64
import json
import sys

with open(sys.argv[1], 'r', encoding='utf-8') as handle:
    user_vars = json.load(handle)

if not isinstance(user_vars, list):
    user_vars = []

token = sys.argv[2].strip()
relationships = []
if token:
    try:
        relationships = json.loads(base64.b64decode(token).decode("utf-8"))
    except Exception:
        relationships = []

merged = {}
for item in user_vars:
    if isinstance(item, dict) and item.get("name"):
        merged[str(item["name"])] = item.get("value", "")

for item in relationships:
    if isinstance(item, dict) and item.get("name"):
        merged[str(item["name"])] = item.get("value", "")

result = [{"name": key, "value": value} for key, value in merged.items()]
print(json.dumps(result, separators=(",", ":")))
PY""",
            returnStdout: true
        ).trim()
    } finally {
        sh "rm -f '${envTempFile}'"
    }
}

def servicesStateToJson(String state) {
    def services = decodeServicesFromState(state)
    def tempFile = '.jenkins-workspace-services.tsv'

    writeFile file: tempFile, text: services.collect { svc ->
        [
            svc.name ?: '',
            svc.framework ?: '',
            svc.appPort ?: '',
            svc.serviceType ?: '',
            svc.customDomain ?: '',
            svc.imageRepository ?: '',
            svc.imageTag ?: '',
            svc.mergedEnvJson ?: '[]',
            svc.syncWave ?: '0'
        ].collect { value ->
            (value?.toString() ?: '')
                .replace('\t', ' ')
                .replace('\n', ' ')
                .replace('\r', ' ')
        }.join('\t')
    }.join('\n')

    try {
        return sh(
            script: """python3 - '${tempFile}' <<'PY'
import json
import sys

services = []

with open(sys.argv[1], 'r', encoding='utf-8') as handle:
    for raw_line in handle:
        line = raw_line.rstrip('\\n')
        if not line:
            continue
        columns = line.split('\\t')
        while len(columns) < 9:
            columns.append('')
        services.append({
            "name": columns[0],
            "framework": columns[1],
            "appPort": columns[2],
            "serviceType": columns[3] or "internal",
            "customDomain": columns[4],
            "imageRepository": columns[5],
            "imageTag": columns[6],
            "envJson": columns[7] or "[]",
            "syncWave": columns[8] or "0",
        })

print(json.dumps(services, separators=(",", ":")))
PY""",
            returnStdout: true
        ).trim()
    } finally {
        sh "rm -f '${tempFile}'"
    }
}

def encodeServicesForState(List services) {
    services.collect { svc ->
        [
            svc.name,
            svc.repoUrl,
            svc.branch,
            svc.repoCredentialsId,
            svc.framework,
            svc.appPort,
            svc.imageTag,
            svc.envJson,
            svc.serviceType,
            svc.customDomain,
            svc.imageRepository,
            svc.commitSha,
            svc.mergedEnvJson,
            ((svc.dependsOn ?: []).collect { it?.toString() ?: '' }.findAll { it }.join('\u001f')),
            svc.relationshipsToken,
            svc.syncWave
        ].collect { encodeStateField(it) }.join('\t')
    }.join('\n')
}

def decodeServicesFromState(String state) {
    if (!state?.trim()) {
        return []
    }

    state.readLines().findAll { it?.trim() }.collect { line ->
        def columns = line.split('\t', -1).collect { decodeStateField(it) }
        [
            name              : columns.size() > 0 ? columns[0] : '',
            repoUrl           : columns.size() > 1 ? columns[1] : '',
            branch            : columns.size() > 2 ? columns[2] : '',
            repoCredentialsId : columns.size() > 3 ? columns[3] : '',
            framework         : columns.size() > 4 ? columns[4] : '',
            appPort           : columns.size() > 5 ? columns[5] : '',
            imageTag          : columns.size() > 6 ? columns[6] : '',
            envJson           : columns.size() > 7 ? columns[7] : '',
            serviceType       : columns.size() > 8 ? columns[8] : '',
            customDomain      : columns.size() > 9 ? columns[9] : '',
            imageRepository   : columns.size() > 10 ? columns[10] : '',
            commitSha         : columns.size() > 11 ? columns[11] : '',
            mergedEnvJson     : columns.size() > 12 ? columns[12] : '',
            dependsOn         : (columns.size() > 13 && columns[13])
                ? columns[13].split('\u001f').findAll { it }
                : [],
            relationshipsToken: columns.size() > 14 ? columns[14] : '',
            syncWave          : columns.size() > 15 ? columns[15] : '0'
        ]
    }
}

def encodeStateField(def value) {
    (value?.toString() ?: '')
        .replace('\\', '\\\\')
        .replace('\t', '\\t')
        .replace('\n', '\\n')
        .replace('\r', '\\r')
}

def decodeStateField(String value) {
    (value ?: '')
        .replace('\\r', '\r')
        .replace('\\n', '\n')
        .replace('\\t', '\t')
        .replace('\\\\', '\\')
}

def slugify(String raw, int maxLen = 40) {
    def normalized = (raw ?: '')
        .toLowerCase()
        .replaceAll(/[^a-z0-9-]+/, '-')
        .replaceAll(/^-+/, '')
        .replaceAll(/-+$/, '')
        .replaceAll(/-{2,}/, '-')

    if (!normalized) {
        normalized = 'x'
    }

    normalized.take(maxLen)
}

def resolveRegistryContext(String rawValue) {
    def normalizedRegistry = (rawValue ?: '')
        .trim()
        .replaceFirst(/^https?:\/\//, '')
        .replaceAll(/\/+$/, '')

    if (!normalizedRegistry) {
        error('REGISTRY_REPOSITORY is required')
    }

    def registryParts = normalizedRegistry.tokenize('/')
    def firstRegistryPart = registryParts ? registryParts[0] : ''
    def hostLikeRegistry = firstRegistryPart.contains('.') || firstRegistryPart.contains(':') || firstRegistryPart == 'localhost'
    def dockerHubMode = !hostLikeRegistry || ['docker.io', 'index.docker.io', 'registry-1.docker.io'].contains(firstRegistryPart)

    if (dockerHubMode) {
        def dockerHubNamespace = ['docker.io', 'index.docker.io', 'registry-1.docker.io'].contains(firstRegistryPart)
            ? (registryParts.size() > 1 ? registryParts[1] : '')
            : firstRegistryPart
        if (!dockerHubNamespace) {
            error('For Docker Hub, REGISTRY_REPOSITORY must be your namespace, for example "your-dockerhub-user" or "docker.io/your-dockerhub-user"')
        }

        return [
            dockerHubMode : true,
            loginServer   : 'docker.io',
            repositoryRoot: "docker.io/${dockerHubNamespace}"
        ]
    }

    if (registryParts.size() < 2) {
        error('For private registries, REGISTRY_REPOSITORY must include registry host and project, for example "harbor.example.com/platform"')
    }

    [
        dockerHubMode : false,
        loginServer   : firstRegistryPart,
        repositoryRoot: normalizedRegistry
    ]
}

def buildImageRepository(String repositoryRoot, String safeProjectName, String safeUserId, boolean dockerHubMode) {
    dockerHubMode
        ? "${repositoryRoot}/${safeProjectName}"
        : "${repositoryRoot}/${safeUserId}/${safeProjectName}"
}

def resolveCommitAndFramework(def svc, String branch, String safeProjectName, int index, String frameworkOverride) {
    def resolvedRepoUrl = svc.repoUrl?.toString()?.trim() ?: ''
    if (resolvedRepoUrl.contains('%')) {
        resolvedRepoUrl = java.net.URLDecoder.decode(resolvedRepoUrl, 'UTF-8')
    }

    def resolvedCommitSha = ''
    def resolvedFramework = frameworkOverride

    dir("service-plan/${index}-${safeProjectName}") {
        deleteDir()
        if (svc.repoCredentialsId?.toString()?.trim()) {
            checkout([
                $class: 'GitSCM',
                branches: [[name: "*/${branch}"]],
                userRemoteConfigs: [[
                    url: resolvedRepoUrl,
                    credentialsId: svc.repoCredentialsId.toString().trim()
                ]]
            ])
        } else {
            git url: resolvedRepoUrl, branch: branch
        }

        resolvedCommitSha = sh(
            script: 'git rev-parse --short=12 HEAD',
            returnStdout: true
        ).trim()

        if (!resolvedFramework) {
            resolvedFramework = sh(
                script: "bash '${env.INFRA_SCRIPTS_DIR}/detect-framework.sh'",
                returnStdout: true
            ).trim()
        }
    }

    [
        commitSha: resolvedCommitSha,
        framework: resolvedFramework
    ]
}
